{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "codex-tool-mocks-hook",
            "timeout": 30,
            "statusMessage": "checking codex-tool-mocks fixtures"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "codex-tool-mocks-hook",
            "timeout": 30,
            "statusMessage": "recording codex-tool-mocks call"
          }
        ]
      }
    ]
  }
}
