{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${PLUGIN_ROOT}/..\" python -m codex_tool_mocks.hook",
            "timeout": 30,
            "statusMessage": "checking codex-tool-mocks fixtures"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${PLUGIN_ROOT}/..\" python -m codex_tool_mocks.hook",
            "timeout": 30,
            "statusMessage": "recording codex-tool-mocks call"
          }
        ]
      }
    ]
  }
}
